# IaC overlay (docker-compose.iac.yml) — must match infrastructure/terraform defaults
# POSTGRES_VOLUME_NAME=easy_devops_postgres_data
# MONGODB_VOLUME_NAME=easy_devops_mongodb_data

# Infrastructure (optional image overrides — defaults use ECR Public for mongo/postgres to reduce Docker Hub rate limits)
# MONGO_IMAGE=mongo:7
# POSTGRES_IMAGE=postgres:16-alpine
# KAFKA_UI_IMAGE=provectuslabs/kafka-ui:v0.7.2

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=users
POSTGRES_PORT=5432
MONGO_DB_NAME=service_a
MONGO_PORT=27017

# Kafka (internal clients use kafka:9092; host port 9094 maps EXTERNAL listener)
KAFKA_BROKERS=kafka:9092
KAFKA_EXTERNAL_PORT=9094
# Service-B publishes user-aggregate JSON to KAFKA_USER_EVENTS_TOPIC, role-aggregate to KAFKA_ROLE_EVENTS_TOPIC
KAFKA_USER_EVENTS_TOPIC=user.events
KAFKA_ROLE_EVENTS_TOPIC=role.events
KAFKA_UI_PORT=8080

# Application ports / clients
SERVICE_A_HTTP_PORT=3000
CORS_ORIGIN=*
FRONTEND_A_PORT=4173
FRONTEND_B_PORT=6006
FRONTEND_C_PORT=6007
FRONTEND_A_VITE_API_PREFIX=/api
# Browser URL for Kafka UI (embedded in admin SPA link on the Kafka page)
FRONTEND_A_VITE_KAFKA_UI_URL=http://localhost:8080
# Display labels on Kafka page (must match topics Service-B publishes to)
FRONTEND_A_VITE_KAFKA_USER_EVENTS_TOPIC=user.events
FRONTEND_A_VITE_KAFKA_ROLE_EVENTS_TOPIC=role.events
SERVICE_B_GRPC_PORT=50051
GRPC_HOST=service-b
GRPC_PORT=50051
MONGO_URI=mongodb://mongodb:27017/service_a
GRPC_LISTEN_ADDR=:50051

# Service-B auth (required for JWT; use a long random string in production)
JWT_SECRET=change-me-in-production
# Bootstrap admin — password is applied ONLY when this user row is first created.
# If Postgres already has `admin` from an earlier run (e.g. with a different password),
# login still uses the password stored in the DB. Fix: docker compose down -v (wipes DB)
# or keep using the old password. Must match README / compose defaults unless you reset data.
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=admin123
# Demo user (role "user" only) — same rule: created once; changing env later does not update password.
SEED_DEMO_USERNAME=demo
SEED_DEMO_PASSWORD=demo123
SEED_DEMO_EMAIL=demo@localhost
# Dev-only: include reset token in forgot-password JSON (never in production)
PASSWORD_RESET_DEV_RETURN_TOKEN=0

# Service-C (default: list cluster topics and subscribe to all non-internal names)
KAFKA_GROUP_ID=service-c-all-topics
KAFKA_DISCOVER_ALL_TOPICS=1
KAFKA_TOPIC_PATTERN=.*
KAFKA_METADATA_MAX_AGE_MS=30000
KAFKA_AUTO_OFFSET_RESET=earliest
